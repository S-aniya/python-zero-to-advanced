   "source": [
    "# Program to print contents of a directory using os module\n",
    "\n",
    "import os\n",
    "\n",
    "# specify path (you can change this)\n",
    "path = \"/\"\n",
    "\n",
    "# get list of files and directories\n",
    "contents = os.listdir(path)\n",
    "\n",
    "# print contents\n",
    "print(\"Contents of directory:\")\n",
    "for item in contents:\n",
    "    print(item)"
   ]
  }
